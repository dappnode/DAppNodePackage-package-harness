PORT=8080
DATA_DIR=./.data
HARNESS_DNP_NAME=package-harness.dnp.dappnode.eth
PACKAGE_MANAGER_MODE=fake
ALLOW_DESTRUCTIVE_PACKAGE_TESTS=true

# Tropibot polling worker. The shared token is suitable for this small trusted
# v1 deployment; a later protocol revision can replace it with per-worker auth.
TROPIBOT_URL=https://tropibot.example
PACKAGE_HARNESS_WORKER_ID=worker-01
PACKAGE_HARNESS_WORKER_TOKEN=replace-with-a-long-random-token
PACKAGE_HARNESS_POLL_SECONDS=10
PACKAGE_HARNESS_HEARTBEAT_SECONDS=20
TROPIBOT_TIMEOUT_MS=15000

# Required when PACKAGE_MANAGER_MODE=mcp
DAPPMANAGER_MCP_URL=http://my.dappnode/mcp
DAPPMANAGER_MCP_TOKEN=replace-with-dappmanager-bearer-token
MCP_TIMEOUT_MS=30000

STABILIZATION_TIMEOUT_MS=180000
STABILIZATION_POLL_MS=5000
STABILIZATION_REQUIRED_SAMPLES=3
LOG_TAIL=300
# Applies to targets the harness installed itself. Targets that were already
# installed are always restored to their recorded pre-test version.
CLEANUP_ENABLED=true
CLEANUP_TIMEOUT_MS=60000

# Optional advisory analysis
NEXUS_API_KEY=
NEXUS_BASE_URL=https://nexus-api.dappnode.com/v1
NEXUS_MODEL=nexus/auto
NEXUS_TIMEOUT_MS=30000
NEXUS_MAX_INPUT_BYTES=65536
