PORT=8080
DATA_DIR=./.data
HARNESS_DNP_NAME=package-harness.dnp.dappnode.eth
HARNESS_API_TOKEN=replace-with-a-long-random-token
PACKAGE_MANAGER_MODE=fake
ALLOW_DESTRUCTIVE_PACKAGE_TESTS=true

# Required when PACKAGE_MANAGER_MODE=mcp
DAPPMANAGER_MCP_URL=http://my.dappnode/mcp
DAPPMANAGER_MCP_TOKEN=replace-with-dappmanager-bearer-token
MCP_TIMEOUT_MS=30000

STABILIZATION_TIMEOUT_MS=180000
STABILIZATION_POLL_MS=5000
STABILIZATION_REQUIRED_SAMPLES=3
LOG_TAIL=300
CLEANUP_ENABLED=true
CLEANUP_TIMEOUT_MS=60000
RECOVER_CLEANUP_ON_START=false

# Result reporting: none, webhook, github_pr_comment, or auto.
# auto keeps backwards compatibility: webhook is used when RESULT_CALLBACK_URL is set.
RESULT_REPORTER=none

# Required when RESULT_REPORTER=webhook, or when auto detects RESULT_CALLBACK_URL
RESULT_CALLBACK_URL=https://github-app.example/harness/results
RESULT_CALLBACK_HMAC_SECRET=replace-with-callback-hmac-secret
RESULT_CALLBACK_TIMEOUT_MS=15000

# Required when RESULT_REPORTER=github_pr_comment
GITHUB_APP_ID=123456
# Either paste the PEM with \n escapes or point at a mounted secret file.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY_FILE=
GITHUB_API_BASE_URL=https://api.github.com

# Optional advisory analysis
NEXUS_API_KEY=
NEXUS_BASE_URL=https://nexus-api.dappnode.com/v1
NEXUS_MODEL=nexus/auto
NEXUS_TIMEOUT_MS=30000
NEXUS_MAX_INPUT_BYTES=65536
